# ─── Supabase PostgreSQL (Project Settings → Database → Connection string) ───
# App runtime (transaction pooler, port 6543) — enable "Use connection pooling"
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Migrations / db push (direct connection, port 5432) — "Direct connection" host db.[ref].supabase.co
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Optional: Supabase client (Storage, Realtime, Auth) — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ─── App ───
JWT_SECRET="change-me-to-a-long-random-string"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Phase 4+ (E-Way Bill credential encryption)
EWB_ENCRYPTION_KEY=""

# Phase 5+ (MSG91 / Twilio)
MSG91_AUTH_KEY=""
TWILIO_ACCOUNT_SID=""

# Cron: GET /api/reminders/run?secret=...
CRON_SECRET="dev-cron"

# ─── Local Docker (alternative to Supabase) ───
# DATABASE_URL="postgresql://marblepro:marblepro@localhost:5432/marblepro?schema=public"
# DIRECT_URL="postgresql://marblepro:marblepro@localhost:5432/marblepro?schema=public"
